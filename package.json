{
  "name": "comvar-readonly",
  "version": "0.1.0",
  "displayName": "ComVar Readonly",
  "description": "Reads Comment Variables.",
  "keywords": [
    "comments",
    "variables",
    "comment-variables"
  ],
  "license": "UNLICENSED",
  "author": "Luther Tchofo Safo <luther@tchofo-safo-portfolio.me>",
  "publisher": "LutherTS",
  "type": "module",
  "main": "source/library/index.js",
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "typescriptServerPlugins": [
      {
        "name": "typescript-server-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ]
  },
  "dependencies": {
    "typescript-server-plugin": "file:plugin"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0"
  }
